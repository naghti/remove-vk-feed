{
  "manifest_version": 3,
  "name": "Remove VK feed",
  "version": "1.0",
  "description": "Удаление ленты vk.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://vk.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
