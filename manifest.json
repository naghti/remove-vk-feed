{
  "manifest_version": 3,
  "name": "Remove VK feed",
  "version": "1.1",
  "description": "Удаление ленты VK с переключателем вкл/выкл.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://vk.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}